[QUEST191]
Nombre=Veneno mortal
Desc=Um desses invasores tem um veneno mortal, tenta derrotá -los e, se você voltar vivo, eu o recompensarei com alguns antídotos para curá -lo.
DescFinal=Ótimo trabalho! Espere .. você está bem? Ele é curado com este antídoto.
Repetible=1
