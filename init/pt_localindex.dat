RequiredLevel=20
PosMap=106

[QUEST24]
Nombre=Dependência de jabalis
Desc=Acabei de observar na costa que o sol está se pressionando e estamos ficando sem provisões para a pousada. Por favor, veja e obtenha dez sacos de javalis!
DescFinal=Estou muito agradecido, você nos salvou. Tome essas moedas como uma recompensa.
