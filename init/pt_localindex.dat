RequiredLevel=5

[QUEST193]
Nombre=O grande lobo feroz
Desc=Entre todos esses lobos, há um que é temido por todos, o grande Wolfang. Ele é o líder da mochila e eliminá -lo, daria -nos a vantagem de poder controlá -los. Ele termina com ele e me traz sua pele, vamos mostrar a essa miserável Manada que é a líder.
DescFinal=Uau, você conseguiu! Esses lobos aprenderão a não entrar em nosso território
Repetible=0
